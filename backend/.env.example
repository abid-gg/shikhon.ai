# Supabase project URL (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — server only; never expose to the browser
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM for question generation (OpenRouter recommended on free tier)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=google/gemini-2.0-flash-exp:free

# Or direct Google Gemini (legacy fallback if LLM_API_KEY unset)
GEMINI_API_KEY=your-gemini-api-key

# Frontend origin for CORS (e.g. Vercel deployment URL)
FRONTEND_URL=http://localhost:3000
